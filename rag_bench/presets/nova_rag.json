{
  "name": "nova-rag",
  "git_url": "https://github.com/user/nova-rag",
  "command": "python -m nova_rag",
  "transport": "stdio",
  "index_dir": "~/.nova-rag",
  "index_dirs": [".nova-rag"],
  "tool_mapping": {
    "ingest": {
      "tool": "rag_index",
      "params": {"path": "{path}"}
    },
    "query": {
      "tool": "code_search",
      "params": {"query": "{query}", "top_k": "{top_k}"}
    }
  }
}
