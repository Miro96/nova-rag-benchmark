{
  "name": "cocoindex-code",
  "git_url": "https://github.com/cocoindex-io/cocoindex",
  "command": "python",
  "args": ["-m", "cocoindex_code.cli", "mcp"],
  "transport": "mcp",
  "cwd": "{repo_path}",
  "pre_ingest_commands": [
    {"cmd": "python", "args": ["-m", "cocoindex_code.cli", "init", "-f"], "cwd_template": "{repo_path}"},
    {"cmd": "python", "args": ["-m", "cocoindex_code.cli", "index"], "cwd_template": "{repo_path}"}
  ],
  "tool_mapping": {
    "query": {
      "tool": "search",
      "params": {"query": "{query}", "limit": "{top_k}"}
    }
  }
}
