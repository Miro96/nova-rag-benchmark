{
  "name": "nova-rag",
  "git_url": "https://github.com/user/nova-rag",
  "command": "python -m nova_rag.server",
  "transport": "stdio",
  "tool_mapping": {
    "ingest": {
      "tool": "index_directory",
      "params": {"path": "{path}"}
    },
    "query": {
      "tool": "code_search",
      "params": {"query": "{query}", "limit": "{top_k}"}
    }
  }
}
